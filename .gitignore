# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem
.claude/
.sync-conflict-*
*.sync-conflict-*
test-results/
playwright-report/
logs/
tmp/
temp/
*.log
*.tmp

