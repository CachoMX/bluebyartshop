# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# workspace artifacts
*.sync-conflict-*
.claude/chrome-smoke-profile/
.claude/smoke-artifacts/
/test-results/
/playwright-report/
